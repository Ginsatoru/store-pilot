{
  "name": "storepilot",
  "version": "1.0.0",
  "description": "Store Pilot - Product Dashboard",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite --port 5174",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0"
  },
  "build": {
    "appId": "com.storepilot.app",
    "productName": "Store Pilot",
    "directories": {
      "output": "dist-electron"
    },
    "icon": "electron/icons/icon",
    "win": {
      "icon": "electron/icons/icon.ico"
    },
    "mac": {
      "icon": "electron/icons/icon.icns"
    },
    "linux": {
      "icon": "electron/icons/icon.png"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*"
    ]
  }
}